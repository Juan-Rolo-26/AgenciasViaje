generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Destino {
  id                Int               @id @default(autoincrement())
  nombre            String
  slug              String            @unique
  paisRegion        String?
  descripcionCorta  String?
  descripcion       String
  imagenPortada     String
  destacado         Boolean           @default(false)
  activo            Boolean           @default(true)
  orden             Int               @default(0)
  tituloSeo         String?
  descripcionSeo    String?
  creadoEn          DateTime          @default(now())

  galeria           ImagenDestino[]
  ofertasPrincipales Oferta[]         @relation("DestinoPrincipal")
  ofertasSecundarias OfertaDestino[]
  actividades       Actividad[]
}

model ImagenDestino {
  id         Int      @id @default(autoincrement())
  destinoId  Int
  imagen     String
  epigrafe   String?
  orden      Int      @default(0)

  destino    Destino  @relation(fields: [destinoId], references: [id], onDelete: Cascade)
}

model Oferta {
  id              Int              @id @default(autoincrement())
  titulo          String
  slug            String           @unique
  destinoId       Int
  noches          Int              @default(1)
  cupos           Int              @default(0)
  noIncluye       String?
  condiciones     String?
  destacada       Boolean          @default(false)
  activa          Boolean          @default(true)
  tipo            String           @default("individual") // "individual", "grupal"
  orden           Int              @default(0)
  tituloSeo       String?
  descripcionSeo  String?
  creadaEn        DateTime         @default(now())

  destino          Destino          @relation("DestinoPrincipal", fields: [destinoId], references: [id])
  destinos         OfertaDestino[]
  actividades      OfertaActividad[]
  precios          PrecioOferta[]
  incluyeItems     IncluyeOferta[]
}

model OfertaDestino {
  ofertaId   Int
  destinoId Int

  oferta     Oferta   @relation(fields: [ofertaId], references: [id], onDelete: Cascade)
  destino    Destino  @relation(fields: [destinoId], references: [id], onDelete: Cascade)

  @@id([ofertaId, destinoId])
}

model PrecioOferta {
  id          Int      @id @default(autoincrement())
  ofertaId    Int
  precio      Decimal
  moneda      String
  fechaInicio DateTime
  fechaFin    DateTime

  oferta      Oferta   @relation(fields: [ofertaId], references: [id], onDelete: Cascade)
}

model IncluyeOferta {
  id          Int           @id @default(autoincrement())
  ofertaId    Int
  tipo        String
  descripcion String

  oferta      Oferta        @relation(fields: [ofertaId], references: [id], onDelete: Cascade)
}

model Actividad {
  id             Int              @id @default(autoincrement())
  nombre         String
  slug           String           @unique
  destinoId      Int
  tipoActividad  String
  fecha          DateTime
  hora           String?
  precio         Decimal
  cupos          Int              @default(0)
  puntoEncuentro String
  descripcion    String
  imagenPortada  String
  destacada      Boolean          @default(false)
  activa         Boolean          @default(true)
  orden          Int              @default(0)
  tituloSeo      String?
  descripcionSeo String?
  creadaEn       DateTime         @default(now())

  destino        Destino          @relation(fields: [destinoId], references: [id])
  ofertas        OfertaActividad[]
}

model OfertaActividad {
  ofertaId    Int
  actividadId Int

  oferta      Oferta     @relation(fields: [ofertaId], references: [id], onDelete: Cascade)
  actividad   Actividad  @relation(fields: [actividadId], references: [id], onDelete: Cascade)

  @@id([ofertaId, actividadId])
}

model SeccionNosotros {
  id             Int      @id @default(autoincrement())
  titulo         String
  contenido      String
  imagen         String?
  tituloSeo      String?
  descripcionSeo String?

  valores        Valor[]
}

model Valor {
  id         Int             @id @default(autoincrement())
  seccionId  Int
  titulo     String
  descripcion String
  icono      String?
  orden      Int             @default(0)

  seccion    SeccionNosotros @relation(fields: [seccionId], references: [id], onDelete: Cascade)
}
